<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/message_avatar_persona"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/default_avatar"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/rounded_message_persona"
        android:paddingStart="0dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginEnd="16dp"
        >

        <TextView
            android:id="@+id/message_text_persona"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:maxWidth="250dp"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:text="Persona 回复内容"
            />

        <ImageButton
            android:id="@+id/btn_tts_play"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_play_arrow"
            android:contentDescription="播放语音"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:visibility="visible"
            />

    </LinearLayout>

</LinearLayout>